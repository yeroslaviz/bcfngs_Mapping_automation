EXECUTABLE_TO_TOOL = {
    executable: spec.key
    for spec in TOOL_SPECS.values()
    for executable in spec.executables
}
RUNTIME_CACHE: dict[tuple[str, str, str, str, str], RuntimeEnvironment] = {}
SHIM_LAYOUT_VERSION = 2


def _run(
    cmd: list[str],
    *,
    check: bool = True,
    capture: bool = False,
    env: dict | None = None,
) -> subprocess.CompletedProcess:
    kwargs = {
        "check": check,
        "text": True,
        "env": env,
    }
    if capture:
        kwargs["stdout"] = subprocess.PIPE
        kwargs["stderr"] = subprocess.PIPE
    return subprocess.run(cmd, **kwargs)  # noqa: S603,S607


def _micromamba() -> str:
    exe = shutil.which("micromamba")
    if not exe:
        raise SystemExit("micromamba not found in PATH. Install micromamba or use --profile modules.")
    return exe


def _ensure_dir(p: Path) -> None:
    p.mkdir(parents=True, exist_ok=True)


def _write_exec_shim(path: Path, target: str) -> None:
    launcher = "\n".join(
        (
            "#!/usr/bin/env bash",
            "set -euo pipefail",
            f"exec {shlex.quote(target)} \"$@\"",
            "",
        )
    )
    path.write_text(launcher, encoding="utf-8")
    path.chmod(0o755)


def _first_nonempty_line(text: str) -> str:
    for line in text.splitlines():
        line = line.strip()
        if line:
            return line
    return ""


def _extract_version_token(text: str) -> str:
    match = re.search(r"\b\d+(?:\.\d+)+(?:[A-Za-z0-9._-]*)\b", text)
    if match:
        return match.group(0).strip()
    return ""


def _extract_bwa_version(out: subprocess.CompletedProcess) -> str:
    combined = f"{out.stdout or ''}\n{out.stderr or ''}"
    for line in combined.splitlines():
        match = re.search(r"\bVersion:\s*([^\s]+)", line)
        if match:
            token = _extract_version_token(match.group(1))
            if token:
                return token
    return _extract_version_token(combined)


def _extract_bowtie2_version(out: subprocess.CompletedProcess) -> str:
    combined = f"{out.stdout or ''}\n{out.stderr or ''}"
    for line in combined.splitlines():
        stripped = line.strip()
        if not stripped:
            continue
        match = re.search(r"\bversion\s+([^\s]+)", stripped, flags=re.IGNORECASE)
        if match:
            token = _extract_version_token(match.group(1))
            if token:
                return token
    return _extract_version_token(combined)


def _extract_star_version(out: subprocess.CompletedProcess) -> str:
    combined = f"{out.stdout or ''}\n{out.stderr or ''}"
    return _extract_version_token(combined)


def _extract_plain_version(text: str) -> str:
    token = _extract_version_token(text)
    if token:
        return token
    return text.strip()


def _extract_tool_version(tool_key: str, out: subprocess.CompletedProcess) -> str:
    combined = f"{out.stdout or ''}\n{out.stderr or ''}"
    if tool_key == "star":
        return _extract_star_version(out)
    if tool_key == "bwa":
        return _extract_bwa_version(out)
    if tool_key == "bowtie2":
        return _extract_bowtie2_version(out)
    if tool_key == "samtools":
        return _extract_plain_version((out.stdout.splitlines() or [""])[0].strip())
    if tool_key == "bamCoverage":
        return _extract_plain_version(_first_nonempty_line(combined))
    if tool_key == "curl":
        first = (out.stdout.splitlines() or [""])[0]
        match = re.search(r"\bcurl\s+([^\s]+)", first)
        if match:
            return _extract_plain_version(match.group(1))
        return _extract_plain_version(first)
    return _extract_plain_version(_first_nonempty_line(combined))


def _env_bin(ctx: RunContext, executable: str) -> str | None:
    candidate = ctx.env_prefix / "bin" / executable
    if candidate.exists():
        return str(candidate)
    return None


def _is_within_env_prefix(ctx: RunContext, path: str | None) -> bool:
    if not path:
        return False
    try:
        return Path(path).resolve().is_relative_to(ctx.env_prefix.resolve())
    except Exception:  # noqa: BLE001
        return False


def _loaded_modules_from_env(env: Mapping[str, str]) -> tuple[str, ...]:
    raw = env.get("LOADEDMODULES", "")
    return tuple(item for item in raw.split(":") if item)


def _find_loaded_module(modules: Iterable[str], aliases: Iterable[str]) -> str | None:
    lowered_aliases = {alias.lower() for alias in aliases}
    for module_name in modules:
        lowered = module_name.lower()
        base = lowered.split("/", 1)[0]
        if base in lowered_aliases:
            return module_name
    return None


def _parse_env_blob(blob: str) -> dict[str, str]:
    env: dict[str, str] = {}
    for entry in blob.split("\0"):
        if not entry:
            continue
        key, _, value = entry.partition("=")
        env[key] = value
    return env


def _module_runtime_env(ctx: RunContext) -> tuple[dict[str, str], tuple[str, ...], tuple[str, ...]]:
    inherited_modules = _loaded_modules_from_env(os.environ)
    missing_defaults: list[str] = []
    for tool_key in INDEXED_TOOLS:
        spec = TOOL_SPECS[tool_key]
        if spec.module_default and not _find_loaded_module(inherited_modules, spec.module_aliases):
            missing_defaults.append(spec.module_default)

    script_lines = ["set -euo pipefail"]
    if missing_defaults:
        quoted_modules = " ".join(shlex.quote(item) for item in missing_defaults)
        script_lines.append('type module >/dev/null 2>&1 || { echo "module command not found in shell startup" >&2; exit 127; }')
        script_lines.append(f"module load {quoted_modules} >/dev/null 2>&1")
    script_lines.append("env -0")
    cp = subprocess.run(  # noqa: S603,S607
        ["bash", "-lc", "\n".join(script_lines)],
        check=False,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        env=os.environ.copy(),
    )
    if cp.returncode != 0:
        details = (cp.stderr or cp.stdout or "").strip()
        msg = "Failed to initialize modules profile environment."
        if details:
            msg += f"\n{details}"
        raise SystemExit(msg)
    resolved_env = _parse_env_blob(cp.stdout)
    final_modules = _loaded_modules_from_env(resolved_env)
    auto_loaded = tuple(item for item in final_modules if item not in inherited_modules)
    return resolved_env, inherited_modules, auto_loaded


def _version_cmd_for_tool(spec: ToolSpec, executable_paths: dict[str, str]) -> list[str]:
    first = spec.version_cmd[0]
    return [executable_paths[first], *spec.version_cmd[1:]]


def _detect_resolved_tool_version(spec: ToolSpec, executable_paths: dict[str, str], env: Mapping[str, str]) -> str:
    cp = _run(_version_cmd_for_tool(spec, executable_paths), check=False, capture=True, env=dict(env))
    return _extract_tool_version(spec.key, cp)


def _resolve_tool(
    ctx: RunContext,
    spec: ToolSpec,
    *,
    base_env: Mapping[str, str],
    preloaded_modules: tuple[str, ...],
    final_modules: tuple[str, ...],
) -> ResolvedTool:
    env_paths = {exe: _env_bin(ctx, exe) for exe in spec.executables}
    env_ready = all(env_paths.values())

    module_paths_raw = {
        exe: shutil.which(exe, path=base_env.get("PATH", ""))
        for exe in spec.executables
    }
    module_paths = {
        exe: path
        for exe, path in module_paths_raw.items()
        if path and not _is_within_env_prefix(ctx, path)
    }
    module_name = _find_loaded_module(final_modules, spec.module_aliases)
    module_ready = bool(module_name) and all(module_paths.get(exe) for exe in spec.executables)
    preloaded_module_name = _find_loaded_module(preloaded_modules, spec.module_aliases)

    chosen_source = "missing"
    chosen_module_name: str | None = None
    chosen_paths: dict[str, str] = {}

    if ctx.profile == "micromamba" or spec.key in ALWAYS_MAMBA_TOOLS:
        if env_ready:
            chosen_source = "micromamba"
            chosen_paths = {exe: path for exe, path in env_paths.items() if path}
    elif spec.key in OPTIONAL_MODULE_TOOLS:
        if preloaded_module_name and module_ready:
            chosen_source = "module"
            chosen_module_name = module_name
            chosen_paths = {exe: path for exe, path in module_paths.items() if path}
        elif env_ready:
            chosen_source = "micromamba"
            chosen_paths = {exe: path for exe, path in env_paths.items() if path}
        elif module_ready:
            chosen_source = "module"
            chosen_module_name = module_name
            chosen_paths = {exe: path for exe, path in module_paths.items() if path}
    else:
        if module_ready:
            chosen_source = "module"
            chosen_module_name = module_name
            chosen_paths = {exe: path for exe, path in module_paths.items() if path}
        elif env_ready:
            chosen_source = "micromamba"
            chosen_paths = {exe: path for exe, path in env_paths.items() if path}

    version = ""
    if chosen_paths:
        version = _detect_resolved_tool_version(spec, chosen_paths, base_env)
    return ResolvedTool(
        key=spec.key,
        display_name=spec.display_name,
        source=chosen_source,
        version=version,
        module_name=chosen_module_name,
        executables=chosen_paths,
    )


def _runtime_cache_key(ctx: RunContext) -> tuple[str, str, str, str, str]:
    return (
        ctx.profile,
        str(ctx.env_prefix),
        os.environ.get("LOADEDMODULES", ""),
        os.environ.get("PATH", ""),
        os.environ.get("LD_LIBRARY_PATH", ""),
    )


def _build_shim_dir(ctx: RunContext, tools: Mapping[str, ResolvedTool], base_env: Mapping[str, str]) -> Path:
    _ensure_dir(REPO_ROOT / ".snakemake" / "bcfngs_shims")
    digest = hashlib.sha256(
        json.dumps(
            {
                "shim_layout_version": SHIM_LAYOUT_VERSION,
                "profile": ctx.profile,
                "env_prefix": str(ctx.env_prefix),
                "loaded_modules": _loaded_modules_from_env(base_env),
                "tools": {
                    tool_key: {
                        "source": tool.source,
                        "module": tool.module_name,
                        "executables": tool.executables,
                    }
                    for tool_key, tool in sorted(tools.items())
                },
            },
            sort_keys=True,
        ).encode("utf-8")
    ).hexdigest()[:16]
    shim_dir = REPO_ROOT / ".snakemake" / "bcfngs_shims" / digest
    _ensure_dir(shim_dir)
    for spec in TOOL_SPECS.values():
        tool = tools[spec.key]
        for executable in spec.executables:
            target = tool.executables.get(executable)
            link_path = shim_dir / executable
            if link_path.exists() or link_path.is_symlink():
                link_path.unlink()
            if target:
                _write_exec_shim(link_path, target)
    return shim_dir


def _build_runtime(ctx: RunContext) -> RuntimeEnvironment:
    if ctx.profile == "micromamba":
        base_env = os.environ.copy()
        preloaded_modules: tuple[str, ...] = ()
        auto_loaded_modules: tuple[str, ...] = ()
    elif ctx.profile == "modules":
        base_env, preloaded_modules, auto_loaded_modules = _module_runtime_env(ctx)
    else:
        raise SystemExit(f"Unknown profile: {ctx.profile}")

    final_modules = _loaded_modules_from_env(base_env)
    tools = {
        tool_key: _resolve_tool(
            ctx,
            spec,
            base_env=base_env,
            preloaded_modules=preloaded_modules,
            final_modules=final_modules,
        )
        for tool_key, spec in TOOL_SPECS.items()
    }
    shim_dir = _build_shim_dir(ctx, tools, base_env)
    runtime_env = dict(base_env)
    runtime_env["PATH"] = f"{shim_dir}:{base_env.get('PATH', '')}"
    runtime_env["CONDA_PREFIX"] = str(ctx.env_prefix)
    return RuntimeEnvironment(
        env=runtime_env,
        tools=tools,
        preloaded_modules=preloaded_modules,
        auto_loaded_modules=auto_loaded_modules,
    )


def _runtime(ctx: RunContext) -> RuntimeEnvironment:
    key = _runtime_cache_key(ctx)
    cached = RUNTIME_CACHE.get(key)
    if cached is None:
        cached = _build_runtime(ctx)
        RUNTIME_CACHE[key] = cached
    return cached


def _resolved_tool(ctx: RunContext, tool_key: str) -> ResolvedTool:
    return _runtime(ctx).tools[tool_key]


def _run_tool(
    ctx: RunContext,
    tool_cmd: list[str],
    *,
    check: bool = True,
    capture: bool = False,
) -> subprocess.CompletedProcess:
    runtime = _runtime(ctx)
    cmd = list(tool_cmd)
    if cmd:
        executable_name = Path(cmd[0]).name
        tool_key = EXECUTABLE_TO_TOOL.get(executable_name)
        if tool_key:
            resolved = runtime.tools[tool_key].executables.get(executable_name)
            if not resolved:
                stderr = f"{executable_name} not found in the selected environment/profile."
                if check:
                    raise SystemExit(stderr)
                return subprocess.CompletedProcess(cmd, 127, "", stderr)
            cmd[0] = resolved
    return _run(cmd, check=check, capture=capture, env=runtime.env)


def _require_tools(ctx: RunContext, tools: Iterable[str]) -> None:
    runtime = _runtime(ctx)
    missing: list[str] = []
    for tool_name in tools:
        tool_key = EXECUTABLE_TO_TOOL.get(tool_name)
        if tool_key:
            resolved = runtime.tools[tool_key]
            if not resolved.executables.get(tool_name):
                missing.append(tool_name)
            continue
        if not shutil.which(tool_name, path=runtime.env.get("PATH", "")):
            missing.append(tool_name)
    if missing:
        raise SystemExit(f"Missing tools in environment: {', '.join(missing)}")


def _tool_report_line(tool: ResolvedTool) -> str:
    if tool.source == "module":
        source = tool.module_name or "module"
    else:
        source = tool.source
    executable = tool.executable()
    version = tool.version or "unknown"
    if executable:
        return f"{tool.display_name}: {source} {version} ({executable})"
    return f"{tool.display_name}: missing"


def _print_tool_report(ctx: RunContext, tool_keys: Iterable[str]) -> None:
    runtime = _runtime(ctx)
    ordered_keys = []
    for tool_key in tool_keys:
        if tool_key not in ordered_keys:
            ordered_keys.append(tool_key)
    print("Resolved tool versions:", file=sys.stderr)
    for tool_key in ordered_keys:
        print(f"  - {_tool_report_line(runtime.tools[tool_key])}", file=sys.stderr)


def _module_report_keys(ctx: RunContext, tool_keys: Iterable[str]) -> list[str]:
    runtime = _runtime(ctx)
    out: list[str] = []
    for tool_key in tool_keys:
        if runtime.tools[tool_key].source == "module" and tool_key not in out:
            out.append(tool_key)
    return out


def _tool_version_or_fail(ctx: RunContext, tool_key: str) -> str:
    tool = _resolved_tool(ctx, tool_key)
    if not tool.version:
        raise SystemExit(f"Failed to detect version for {tool.display_name}. Run './scripts/bcfngs env check'.")
    return tool.version


def _requested_index_versions_from_args(args: argparse.Namespace) -> dict[str, str | None]:
    return {
        "star": getattr(args, "star_index_version", None),
        "bwa": getattr(args, "bwa_index_version", None),
        "bowtie2": getattr(args, "bowtie2_index_version", None),
    }


def _select_index_versions(ctx: RunContext, args: argparse.Namespace) -> tuple[dict[str, str], dict[str, str]]:
    actual_versions = {tool: _tool_version_or_fail(ctx, tool) for tool in INDEXED_TOOLS}
    selected_versions: dict[str, str] = {}
    for tool_key, requested in _requested_index_versions_from_args(args).items():
        actual = actual_versions[tool_key]
        if requested and requested != actual:
            raise SystemExit(
                f"--{tool_key}-index-version {requested!r} does not match the resolved {TOOL_SPECS[tool_key].display_name} "
                f"binary version {actual!r}."
            )
        selected_versions[tool_key] = requested or actual
    return actual_versions, selected_versions


def cmd_env_create(ctx: RunContext, args: argparse.Namespace) -> None:
    mm = _micromamba()
    env_yml = REPO_ROOT / "env" / "environment.yml"
    _ensure_dir(ctx.env_prefix.parent)
    _run([mm, "create", "-y", "-p", str(ctx.env_prefix), "-f", str(env_yml)])


def cmd_env_update(ctx: RunContext, args: argparse.Namespace) -> None:
    mm = _micromamba()
    env_yml = REPO_ROOT / "env" / "environment.yml"
    _run([mm, "update", "-y", "-p", str(ctx.env_prefix), "-f", str(env_yml)])


def _write_temp_config_json(data: dict, *, prefix: str = "bcfngs-config-") -> Path:
    tmp_dir = REPO_ROOT / ".snakemake" / "bcfngs_tmp"
    _ensure_dir(tmp_dir)
    fh = tempfile.NamedTemporaryFile(
        mode="w",
        prefix=prefix,
        suffix=".json",
        delete=False,
        dir=tmp_dir,
    )
    with fh:
        json.dump(data, fh)
    return Path(fh.name)


def cmd_env_check(ctx: RunContext, args: argparse.Namespace) -> None:
    if ctx.profile == "modules":
        module_keys = _module_report_keys(ctx, ENV_CHECK_REPORT_TOOLS)
        if module_keys:
            _print_tool_report(ctx, module_keys)
    _require_tools(ctx, ["python", "snakemake", "STAR", "bwa", "bowtie2-build", "samtools", "curl", "bamCoverage"])
    bwa_out = _run_tool(ctx, ["bwa"], check=False, capture=True)
    star_out = _run_tool(ctx, ["STAR", "--version"], check=False, capture=True)
    bowtie2_out = _run_tool(ctx, ["bowtie2-build", "--version"], check=False, capture=True)
    samtools_line = (_run_tool(ctx, ["samtools", "--version"], capture=True).stdout.splitlines() or [""])[0].strip()
    bamcoverage_out = _run_tool(ctx, ["bamCoverage", "--version"], check=False, capture=True)
    bamcoverage_line = _first_nonempty_line(f"{bamcoverage_out.stdout or ''}\n{bamcoverage_out.stderr or ''}")
    versions = {
        "snakemake": _resolved_tool(ctx, "snakemake").version,
        "STAR": _extract_star_version(star_out),
        "bwa": _extract_bwa_version(bwa_out),
        "bowtie2": _extract_bowtie2_version(bowtie2_out),
        "samtools": _extract_plain_version(samtools_line),
        "bamCoverage": _extract_plain_version(bamcoverage_line),
    }
    print(json.dumps(versions, indent=2))


def _load_yaml(ctx: RunContext, path: Path) -> dict:
    out = _run_tool(
        ctx,
        ["python", "-c", "import sys,yaml,json; print(json.dumps(yaml.safe_load(open(sys.argv[1]))))", str(path)],
        check=False,
        capture=True,
    )
    if out.returncode != 0:
        details = (out.stderr or out.stdout or "").strip()
        msg = f"Could not parse YAML file: {path}"
        if details:
            msg += f"\n{details}"
        raise SystemExit(msg)
    return json.loads(out.stdout)


def _load_yaml_direct(env_prefix: Path, path: Path) -> dict:
    env_python = env_prefix / "bin" / "python"
    if env_python.exists():
        out = _run(
            [
                str(env_python),
                "-c",
                "import sys,yaml,json; print(json.dumps(yaml.safe_load(open(sys.argv[1]))))",
                str(path),
            ],
            check=False,
            capture=True,
        )
        if out.returncode != 0:
            details = (out.stderr or out.stdout or "").strip()
            msg = f"Cannot read {path} for --list-org with {env_python}."
            if details:
                msg += f"\n{details}"
            raise SystemExit(msg)
        return json.loads(out.stdout)
    try:
        import yaml  # type: ignore[import-not-found]
    except ImportError as exc:  # pragma: no cover - depends on host python
        raise SystemExit(
            f"Cannot read {path} for --list-org. No python executable was found in {env_prefix / 'bin'} "
            "and the current python does not provide PyYAML."
        ) from exc
    with path.open() as handle:
        return yaml.safe_load(handle)


def _check_write_permission(path: Path) -> None:
    test_dir = path / ".bcfngs_write_test"
    try:
        test_dir.mkdir(parents=True, exist_ok=True)
        (test_dir / "x").write_text("x")
        (test_dir / "x").unlink(missing_ok=True)
        test_dir.rmdir()
    except Exception as e:  # noqa: BLE001
        raise SystemExit(f"No write permission to {path}: {e}") from e


def _check_urls(ctx: RunContext, urls: Iterable[tuple[str, str, str]]) -> None:
    for org_key, url_kind, url in urls:
        cp = _run_tool(ctx, ["curl", "-fsSI", url], check=False, capture=True)
        if cp.returncode != 0:
            details = (cp.stderr or cp.stdout or "").strip()
            msg = f"{url_kind} URL for {org_key} failed: {url}"
            if details:
                msg += f"\n{details}"
            raise SystemExit(msg)
        print(f"{url_kind} URL for {org_key} is OK")


def cmd_genomes_check_updates(ctx: RunContext, args: argparse.Namespace) -> None:
    _print_tool_report(ctx, ("python", "curl"))
    genomes_cfg = REPO_ROOT / "configs" / "genomes.yaml"
    cfg = _load_yaml(ctx, genomes_cfg)
    source_keys: list[tuple[str, str | None]] = []
    for org_key in cfg["organisms"]:
        source_key = _org_source_key(cfg, org_key)
        if source_key not in source_keys:
            source_keys.append(source_key)

    latest_by_source = {
        source_key: _latest_release_for_source(ctx, *source_key)
        for source_key in source_keys
    }

    for source, division in source_keys:
        label = _source_release_label(source, division)
        current = _current_pinned_release(cfg, source, division)
        latest = latest_by_source[(source, division)]
        if current is None:
            continue
        if latest is None:
            print(f"{label} latest release: (unavailable; network blocked?)  current pinned: {current}")
            continue
        status = "OK" if latest == current else "UPDATE_AVAILABLE"
        print(f"{label} latest release: {latest}  current pinned: {current}  status: {status}")
        if latest != current:
            if source == "ensemblgenomes" and division:
                print(f"Suggested bump: set releases.ensemblgenomes.{division} to {latest} in configs/genomes.yaml")
            else:
                print(f"Suggested bump: set releases.ensembl to {latest} in configs/genomes.yaml")

    print("Assembly availability at latest visible release:")
    for org_key in cfg["organisms"]:
        source, division = _org_source_key(cfg, org_key)
        latest = latest_by_source[(source, division)]
        label = _source_release_label(source, division)
        if latest is None:
            print(
                f"  - {org_key}: assembly {_assembly_for_org(cfg, org_key)}  "
                f"source: {label}  status: CHECK_UNAVAILABLE"
            )
            continue

        assembly_status = _assembly_status_for_org(ctx, cfg, org_key, latest)
        status = str(assembly_status["status"])
        current_assembly = str(assembly_status["current_assembly"])
        line = (
            f"  - {org_key}: assembly {current_assembly}  "
            f"source: {label} {latest}  status: {status}"
        )
        if status == "ASSEMBLY_UPDATE_AVAILABLE":
            available = [str(item) for item in assembly_status["available_assemblies"]]
            line += f"  available: {_format_values(available)}"
        elif status == "ASSEMBLY_PARTIAL_MATCH":
            fasta_assemblies = [str(item) for item in assembly_status["fasta_assemblies"]]
            gtf_assemblies = [str(item) for item in assembly_status["gtf_assemblies"]]
            line += (
                f"  FASTA: {_format_values(fasta_assemblies)}"
                f"  GTF: {_format_values(gtf_assemblies)}"
            )
        elif status == "ASSEMBLY_NOT_FOUND":
            fasta_assemblies = [str(item) for item in assembly_status["fasta_assemblies"]]
            gtf_assemblies = [str(item) for item in assembly_status["gtf_assemblies"]]
            line += (
                f"  FASTA: {_format_values(fasta_assemblies)}"
                f"  GTF: {_format_values(gtf_assemblies)}"
            )
        print(line)

        if status == "ASSEMBLY_UPDATE_AVAILABLE":
            available = [str(item) for item in assembly_status["available_assemblies"]]
            if len(available) == 1:
                print(f"    Suggested assembly update: set organisms.{org_key}.assembly to {available[0]}")


def _species_prefix(species: str) -> str:
    parts = species.split("_")
    if not parts:
        return species
    return "_".join([parts[0].capitalize(), *parts[1:]])


def _release_for_org(cfg: dict, org_key: str) -> str:
    org = cfg["organisms"][org_key]
    if org.get("source") == "ensemblgenomes":
        division = org.get("division")
        return str(cfg["releases"]["ensemblgenomes"][division])
    return str(cfg["releases"]["ensembl"])


def _assembly_for_org(cfg: dict, org_key: str) -> str:
    return str(cfg["organisms"][org_key]["assembly"])


def _source_root_for_org(cfg: dict, org_key: str, release: str | None = None) -> str:
    org = cfg["organisms"][org_key]
    if org.get("source") == "ensemblgenomes":
        division = org["division"]
        rel = release or _release_for_org(cfg, org_key)
        return f"https://ftp.ensemblgenomes.ebi.ac.uk/pub/{division}/release-{rel}"
    rel = release or _release_for_org(cfg, org_key)
    return f"https://ftp.ensembl.org/pub/release-{rel}"


def _normalize_ensemblgenomes_url(url: str) -> str:
    return url.replace(
        "https://ftp.ensemblgenomes.org/",
        "https://ftp.ensemblgenomes.ebi.ac.uk/",
        1,
    )


def _fasta_url_for_org(cfg: dict, org_key: str) -> str:
    org = cfg["organisms"][org_key]
    if "fasta_url" in org:
        return _normalize_ensemblgenomes_url(org["fasta_url"])
    root = _source_root_for_org(cfg, org_key)
    species = org["species"]
    assembly = _assembly_for_org(cfg, org_key)
    fasta_kind = org.get("fasta_kind", "dna.toplevel")
    prefix = _species_prefix(species)
    return f"{root}/fasta/{species}/dna/{prefix}.{assembly}.{fasta_kind}.fa.gz"


def _gtf_url_for_org(cfg: dict, org_key: str) -> str:
    org = cfg["organisms"][org_key]
    if "gtf_url" in org:
        return _normalize_ensemblgenomes_url(org["gtf_url"])
    root = _source_root_for_org(cfg, org_key)
    species = org["species"]
    assembly = _assembly_for_org(cfg, org_key)
    rel = _release_for_org(cfg, org_key)
    gtf_kind = org.get("gtf_kind", "gtf")
    prefix = _species_prefix(species)
    return f"{root}/gtf/{species}/{prefix}.{assembly}.{rel}.{gtf_kind}.gz"


def _genomes_urls_from_cfg(cfg: dict) -> list[tuple[str, str, str]]:
    urls: list[tuple[str, str, str]] = []
    for org_key in cfg["organisms"]:
        urls.append((org_key, "FASTA", _fasta_url_for_org(cfg, org_key)))
        urls.append((org_key, "GTF", _gtf_url_for_org(cfg, org_key)))
    return urls


def _source_release_label(source: str, division: str | None = None) -> str:
    if source == "ensemblgenomes":
        return f"EnsemblGenomes {division}"
    return "Ensembl"


def _latest_release_index_url(source: str, division: str | None = None) -> str:
    if source == "ensemblgenomes":
        if not division:
            raise ValueError("division is required for ensemblgenomes release checks")
        return f"https://ftp.ensemblgenomes.ebi.ac.uk/pub/{division}/"
    return "https://ftp.ensembl.org/pub/"


def _current_pinned_release(cfg: dict, source: str, division: str | None = None) -> int | None:
    releases = cfg.get("releases", {})
    if source == "ensemblgenomes":
        if not division:
            return None
        division_releases = releases.get("ensemblgenomes", {})
        value = division_releases.get(division)
        return int(value) if value is not None else None
    value = releases.get("ensembl")
    return int(value) if value is not None else None


def _org_source_key(cfg: dict, org_key: str) -> tuple[str, str | None]:
    org = cfg["organisms"][org_key]
    return str(org.get("source", "ensembl")), org.get("division")


def _fetch_url_text(ctx: RunContext, url: str) -> str | None:
    try:
        return _run_tool(ctx, ["curl", "-fsSL", url], capture=True).stdout
    except subprocess.CalledProcessError:
        return None


def _latest_release_for_source(ctx: RunContext, source: str, division: str | None = None) -> int | None:
    html = _fetch_url_text(ctx, _latest_release_index_url(source, division))
    if html is None:
        return None
    releases = [int(m.group(1)) for m in re.finditer(r"release-(\d+)/", html)]
    return max(releases) if releases else None


def _listing_filenames(html: str) -> set[str]:
    return {
        match.group(1)
        for match in re.finditer(r'href="([^"/][^"]+)"', html)
        if match.group(1) not in {".", ".."}
    }


def _assemblies_from_fasta_listing(cfg: dict, org_key: str, html: str) -> list[str]:
    org = cfg["organisms"][org_key]
    prefix = _species_prefix(org["species"])
    fasta_kind = org.get("fasta_kind", "dna.toplevel")
    suffix = f".{fasta_kind}.fa.gz"
    assemblies = {
        name[len(prefix) + 1 : -len(suffix)]
        for name in _listing_filenames(html)
        if name.startswith(f"{prefix}.") and name.endswith(suffix)
    }
    return sorted((assembly for assembly in assemblies if assembly), key=_version_key)


def _assemblies_from_gtf_listing(cfg: dict, org_key: str, release: int, html: str) -> list[str]:
    org = cfg["organisms"][org_key]
    prefix = _species_prefix(org["species"])
    gtf_kind = org.get("gtf_kind", "gtf")
    suffix = f".{release}.{gtf_kind}.gz"
    assemblies = {
        name[len(prefix) + 1 : -len(suffix)]
        for name in _listing_filenames(html)
        if name.startswith(f"{prefix}.") and name.endswith(suffix)
    }
    return sorted((assembly for assembly in assemblies if assembly), key=_version_key)


def _format_values(values: Iterable[str], *, limit: int = 5) -> str:
    ordered = [value for value in values if value]
    if not ordered:
        return "(none)"
    preview = ordered[:limit]
    suffix = "" if len(ordered) <= limit else f", +{len(ordered) - limit} more"
    return ", ".join(preview) + suffix


def _assembly_status_for_org(
    ctx: RunContext,
    cfg: dict,
    org_key: str,
    latest_release: int,
) -> dict[str, object]:
    org = cfg["organisms"][org_key]
    current_assembly = _assembly_for_org(cfg, org_key)
    release_str = str(latest_release)
    fasta_listing = _fetch_url_text(
        ctx,
        f"{_source_root_for_org(cfg, org_key, release_str)}/fasta/{org['species']}/dna/",
    )
    gtf_listing = _fetch_url_text(
        ctx,
        f"{_source_root_for_org(cfg, org_key, release_str)}/gtf/{org['species']}/",
    )
    if fasta_listing is None or gtf_listing is None:
        return {
            "status": "CHECK_UNAVAILABLE",
            "current_assembly": current_assembly,
            "fasta_assemblies": [],
            "gtf_assemblies": [],
            "available_assemblies": [],
        }

    fasta_assemblies = _assemblies_from_fasta_listing(cfg, org_key, fasta_listing)
    gtf_assemblies = _assemblies_from_gtf_listing(cfg, org_key, latest_release, gtf_listing)
    available_assemblies = sorted(set(fasta_assemblies) & set(gtf_assemblies), key=_version_key)

    if current_assembly in available_assemblies:
        status = "OK"
    elif available_assemblies:
        status = "ASSEMBLY_UPDATE_AVAILABLE"
    elif current_assembly in fasta_assemblies or current_assembly in gtf_assemblies:
        status = "ASSEMBLY_PARTIAL_MATCH"
    else:
        status = "ASSEMBLY_NOT_FOUND"

    return {
        "status": status,
        "current_assembly": current_assembly,
        "fasta_assemblies": fasta_assemblies,
        "gtf_assemblies": gtf_assemblies,
        "available_assemblies": available_assemblies,
    }


def _snakemake_available_executors(ctx: RunContext) -> set[str]:
    out = _run_tool(ctx, ["snakemake", "--help"], check=False, capture=True)
    if out.returncode != 0:
        details = (out.stderr or out.stdout or "").strip()
        msg = (
            "Failed to run 'snakemake --help' in the selected environment.\n"
            f"env-prefix: {ctx.env_prefix}\n"
            "Use an environment that contains snakemake (and slurm executor plugin if needed), e.g.:\n"
            "  ./scripts/bcfngs --env-prefix /fs/gpfs41/lv07/fileset07/home/b_cox/yeroslaviz/miniconda3/envs/update_genomes genomes build ...\n"
            "or update/create the environment first:\n"
            "  ./scripts/bcfngs --env-prefix /fs/gpfs41/lv07/fileset07/home/b_cox/yeroslaviz/miniconda3/envs/update_genomes env update"
        )
        if details:
            msg += f"\n\nsnakemake output:\n{details}"
        raise SystemExit(msg)
    help_text = f"{out.stdout}\n{out.stderr}"
    match = re.search(r"--executor\s+\{([^}]+)\}", help_text)
    if not match:
        return set()
    return {x.strip() for x in match.group(1).split(",") if x.strip()}


def _require_snakemake_slurm_executor(ctx: RunContext) -> None:
    executors = _snakemake_available_executors(ctx)
    if "slurm" in executors:
        return
    available = ", ".join(sorted(executors)) if executors else "unknown"
    raise SystemExit(
        "Requested --executor slurm, but this Snakemake installation has no slurm executor "
        f"(available executors: {available}).\n"
        "Update environment and try again:\n"
        "  ./scripts/bcfngs env update"
    )


def _selected_orgs(cfg: dict, organism_arg: str | None) -> list[str]:
    all_orgs = list(cfg["organisms"])
    if not organism_arg:
        return all_orgs
    requested = [item.strip() for item in organism_arg.split(",") if item.strip()]
    missing = sorted(set(requested) - set(all_orgs))
    if missing:
        raise SystemExit(f"Unknown organism(s): {', '.join(missing)}")
    return requested


def _org_source_label(cfg: dict, org_key: str) -> str:
    org = cfg["organisms"][org_key]
    source = org.get("source", "ensembl")
    if source == "ensemblgenomes" and org.get("division"):
        return f"{source}/{org['division']}"
    return source


def cmd_list_org(env_prefix: Path) -> None:
    genomes_cfg_path = REPO_ROOT / "configs" / "genomes.yaml"
    cfg = _load_yaml_direct(env_prefix, genomes_cfg_path)
    rows = [
        (
            org_key,
            cfg["organisms"][org_key].get("assembly", ""),
            _org_source_label(cfg, org_key),
            _release_for_org(cfg, org_key),
        )
        for org_key in cfg["organisms"]
    ]
    headers = ("Organism", "Assembly", "Source", "Release")
    widths = [
        max(len(header), *(len(str(row[idx])) for row in rows))
        for idx, header in enumerate(headers)
    ]
    print("Configured organisms:")
    print("  " + "  ".join(header.ljust(widths[idx]) for idx, header in enumerate(headers)))
    for row in rows:
        print("  " + "  ".join(str(value).ljust(widths[idx]) for idx, value in enumerate(row)))


def _prepare_genomes_config(
    ctx: RunContext,
    args: argparse.Namespace,
) -> tuple[dict, dict[str, str], dict[str, str], list[str]]:
    genomes_cfg_path = REPO_ROOT / "configs" / "genomes.yaml"
    cfg = _load_yaml(ctx, genomes_cfg_path)
    actual_versions, selected_versions = _select_index_versions(ctx, args)
    cfg["index_versions"] = selected_versions
    orgs = _selected_orgs(cfg, getattr(args, "organism", None))
    if orgs and len(orgs) != len(cfg["organisms"]):
        cfg["org_subset"] = ",".join(orgs)
    return cfg, actual_versions, selected_versions, orgs


def cmd_genomes_plan(ctx: RunContext, args: argparse.Namespace) -> None:
    _print_tool_report(ctx, GENOMES_REPORT_TOOLS)
    cfg, actual_versions, selected_versions, _orgs = _prepare_genomes_config(ctx, args)
    genomes_cfg_path = REPO_ROOT / "configs" / "genomes.yaml"
    print(f"Config file is OK: {genomes_cfg_path}")

    releases = cfg.get("releases", {})
    if "ensembl" in releases:
        print(f"Genome build release: Ensembl {releases['ensembl']}")
    for division, rel in sorted(releases.get("ensemblgenomes", {}).items()):
        print(f"Genome build release: EnsemblGenomes {division} {rel}")

    print("Resolved tool versions:", json.dumps(actual_versions, indent=2))
    print("Target index version labels:", json.dumps(selected_versions, indent=2))

    genomes_root = Path(cfg["genomes_root"])
    _check_write_permission(genomes_root)
    _check_urls(ctx, _genomes_urls_from_cfg(cfg))

    smk = REPO_ROOT / "workflow" / "genomes.smk"
    lint_cp = _run_tool(ctx, ["snakemake", "--lint", "-s", str(smk)], check=False, capture=True)
    if lint_cp.returncode != 0:
        print(f"Warning: snakemake --lint returned exit code {lint_cp.returncode}; continuing with dry-run.")
        lint_out = (lint_cp.stdout or "").strip()
        lint_err = (lint_cp.stderr or "").strip()
        if lint_out:
            print(lint_out)
        if lint_err:
            print(lint_err)

    tmp_cfg_path = _write_temp_config_json(cfg, prefix="bcfngs-genomes-")
    try:
        _run_tool(
            ctx,
            [
                "snakemake",
                "--dry-run",
                "--printshellcmds",
                "-s",
                str(smk),
                "--configfile",
                str(tmp_cfg_path),
            ],
        )
    finally:
        tmp_cfg_path.unlink(missing_ok=True)


def _tool_index_dirname(tool_key: str) -> str:
    return {
        "star": "starIndex",
        "bwa": "bwaIndex",
        "bowtie2": "bowtie2Index",
    }[tool_key]


def _tool_versioned_dirname(tool_key: str, version: str, *, assembly: str | None = None) -> str:
    base = f"{_tool_index_dirname(tool_key)}-{version}"
    if assembly:
        return f"{assembly}-{base}"
    return base


def _tool_versioned_dir(
    genomes_root: Path,
    organism: str,
    tool_key: str,
    version: str,
    *,
    assembly: str | None = None,
) -> Path:
    return genomes_root / organism / _tool_versioned_dirname(tool_key, version, assembly=assembly)


def _tool_versioned_dir_candidates(
    genomes_root: Path,
    organism: str,
    tool_key: str,
    version: str,
    *,
    assembly: str | None = None,
) -> list[Path]:
    candidates: list[Path] = []
    if assembly:
        candidates.append(_tool_versioned_dir(genomes_root, organism, tool_key, version, assembly=assembly))
    legacy = _tool_versioned_dir(genomes_root, organism, tool_key, version)
    if legacy not in candidates:
        candidates.append(legacy)
    return candidates


def _tool_stable_link(genomes_root: Path, organism: str, tool_key: str) -> Path:
    return genomes_root / organism / _tool_index_dirname(tool_key)


def _tool_index_resource_path(base: Path, organism: str, tool_key: str) -> Path:
    if tool_key == "star":
        return base / "SA"
    if tool_key == "bwa":
        return base / f"{organism}.bwt"
    return base / f"{organism}.1.bt2"


def _tool_expected_index_paths(
    genomes_root: Path,
    organism: str,
    tool_key: str,
    version: str | None = None,
    *,
    assembly: str | None = None,
) -> list[Path]:
    if version:
        bases = _tool_versioned_dir_candidates(genomes_root, organism, tool_key, version, assembly=assembly)
    else:
        bases = [_tool_stable_link(genomes_root, organism, tool_key)]
    return [_tool_index_resource_path(base, organism, tool_key) for base in bases]


def _tool_existing_versioned_dir(
    genomes_root: Path,
    organism: str,
    tool_key: str,
    version: str,
    *,
    assembly: str | None = None,
) -> Path | None:
    for candidate in _tool_versioned_dir_candidates(genomes_root, organism, tool_key, version, assembly=assembly):
        if _tool_index_resource_path(candidate, organism, tool_key).exists():
            return candidate
    return None


def _index_dir_metadata(tool_key: str, path: Path) -> tuple[str | None, str] | None:
    dirname = _tool_index_dirname(tool_key)
    legacy_prefix = f"{dirname}-"
    if path.name.startswith(legacy_prefix):
        version = path.name[len(legacy_prefix) :]
        return (None, version) if version else None
    marker = f"-{dirname}-"
    if marker not in path.name:
        return None
    assembly, version = path.name.split(marker, 1)
    if not assembly or not version:
        return None
    return assembly, version


def _version_from_index_dirname(tool_key: str, path: Path) -> str | None:
    metadata = _index_dir_metadata(tool_key, path)
    if metadata is None:
        return None
    return metadata[1]


def _assembly_from_index_dirname(tool_key: str, path: Path) -> str | None:
    metadata = _index_dir_metadata(tool_key, path)
    if metadata is None:
        return None
    return metadata[0]


def _stable_link_version(link_path: Path, tool_key: str) -> str | None:
    if not link_path.exists() or not link_path.is_symlink():
        return None
    try:
        target = link_path.resolve()
    except OSError:
        return None
    return _version_from_index_dirname(tool_key, target)


def _stable_link_assembly(link_path: Path, tool_key: str) -> str | None:
    if not link_path.exists() or not link_path.is_symlink():
        return None
    try:
        target = link_path.resolve()
    except OSError:
        return None
    return _assembly_from_index_dirname(tool_key, target)


def _version_key(version: str) -> tuple[tuple[int, object], ...]:
    parts = re.findall(r"\d+|[A-Za-z]+|[^A-Za-z\d]+", version.lower())
    key: list[tuple[int, object]] = []
    for part in parts:
        if part.isdigit():
            key.append((0, int(part)))
        else:
            key.append((1, part))
    return tuple(key)


def _update_symlink(link_path: Path, target: Path) -> None:
    _ensure_dir(link_path.parent)
    tmp_link = link_path.with_name(f"{link_path.name}.tmp.{os.getpid()}")
    if tmp_link.exists() or tmp_link.is_symlink():
        tmp_link.unlink()
    tmp_link.symlink_to(target)
    os.replace(tmp_link, link_path)


def _scan_index_versions(
    genomes_root: Path,
    organism: str,
    tool_key: str,
    *,
    assembly: str | None = None,
) -> dict[str, Path]:
    organism_dir = genomes_root / organism
    found: dict[str, Path] = {}
    if not organism_dir.exists():
        return found
    for candidate in organism_dir.iterdir():
        if not candidate.is_dir():
            continue
        metadata = _index_dir_metadata(tool_key, candidate)
        if metadata is None:
            continue
        candidate_assembly, version = metadata
        if assembly is not None and candidate_assembly not in {None, assembly}:
            continue
        expected = _tool_index_resource_path(candidate, organism, tool_key)
        if expected.exists():
            current = found.get(version)
            if current is None:
                found[version] = candidate
                continue
            current_assembly = _assembly_from_index_dirname(tool_key, current)
            if assembly is not None and candidate_assembly == assembly and current_assembly != assembly:
                found[version] = candidate
    return found


def _tool_manifest_snapshot(tool: ResolvedTool) -> dict:
    return {
        "source": tool.source,
        "module_name": tool.module_name,
        "version": tool.version or None,
        "executable": tool.executable(),
    }


def _load_existing_manifest(manifest_path: Path) -> dict:
    if not manifest_path.exists():
        return {}
    try:
        return json.loads(manifest_path.read_text())
    except Exception:  # noqa: BLE001
        return {}


def _manifest_assembly(genomes_root: Path, organism: str) -> str | None:
    manifest = _load_existing_manifest(genomes_root / organism / MANIFEST_FILE_NAME)
    assembly = manifest.get("assembly")
    return str(assembly) if assembly else None


def _write_index_manifest(
    cfg: dict,
    genomes_root: Path,
    organism: str,
    *,
    runtime: RuntimeEnvironment,
    build_versions: Mapping[str, str],
    build_timestamp: str,
) -> None:
    organism_dir = genomes_root / organism
    manifest_path = organism_dir / MANIFEST_FILE_NAME
    existing = _load_existing_manifest(manifest_path)
    org_cfg = cfg["organisms"][organism]
    current_assembly = _assembly_for_org(cfg, organism)

    stable_targets: dict[str, dict[str, str | None]] = {}
    index_builds: dict[str, dict[str, dict]] = {}
    existing_builds = existing.get("index_builds", {})

    for tool_key in INDEXED_TOOLS:
        scanned = _scan_index_versions(genomes_root, organism, tool_key, assembly=current_assembly)
        stable_version = _stable_link_version(_tool_stable_link(genomes_root, organism, tool_key), tool_key)
        stable_targets[tool_key] = {
            "version": stable_version,
            "path": str(_tool_stable_link(genomes_root, organism, tool_key).resolve()) if stable_version else None,
        }
        tool_entries: dict[str, dict] = {}
        previous_entries = existing_builds.get(tool_key, {})
        for version, path in sorted(scanned.items(), key=lambda item: _version_key(item[0])):
            previous = previous_entries.get(version, {})
            built_at = previous.get("built_at")
            if build_versions.get(tool_key) == version:
                built_at = build_timestamp
            tool_entries[version] = {
                "version": version,
                "path": str(path),
                "built_at": built_at,
                "is_stable_target": version == stable_version,
            }
        index_builds[tool_key] = tool_entries

    manifest = {
        "organism": organism,
        "assembly": current_assembly,
        "source": {
            "provider": org_cfg.get("source", "ensembl"),
            "division": org_cfg.get("division"),
            "ensembl_release": _release_for_org(cfg, organism) if org_cfg.get("source") != "ensemblgenomes" else None,
            "ensemblgenomes_release": _release_for_org(cfg, organism) if org_cfg.get("source") == "ensemblgenomes" else None,
            "fasta_url": _fasta_url_for_org(cfg, organism),
            "gtf_url": _gtf_url_for_org(cfg, organism),
        },
        "stable_targets": stable_targets,
        "tool_versions_used_for_build": {
            TOOL_SPECS[tool_key].display_name: _tool_manifest_snapshot(runtime.tools[tool_key])
            for tool_key in GENOMES_REPORT_TOOLS
        },
        "updated_at": build_timestamp,
        "index_builds": index_builds,
    }
    manifest_path.write_text(json.dumps(manifest, indent=2, sort_keys=True) + "\n")


def _postprocess_genomes_build(
    cfg: dict,
    organisms: Iterable[str],
    *,
    runtime: RuntimeEnvironment,
    build_versions: Mapping[str, str],
) -> None:
    genomes_root = Path(cfg["genomes_root"]).expanduser()
    build_timestamp = datetime.now(timezone.utc).replace(microsecond=0).isoformat()
    for organism in organisms:
        current_assembly = _assembly_for_org(cfg, organism)
        for tool_key in INDEXED_TOOLS:
            versions = _scan_index_versions(genomes_root, organism, tool_key, assembly=current_assembly)
            if not versions:
                continue
            latest_version = max(versions, key=_version_key)
            _update_symlink(_tool_stable_link(genomes_root, organism, tool_key), versions[latest_version])
        _write_index_manifest(
            cfg,
            genomes_root,
            organism,
            runtime=runtime,
            build_versions=build_versions,
            build_timestamp=build_timestamp,
        )


def cmd_genomes_build(ctx: RunContext, args: argparse.Namespace) -> None:
    if args.no_skip_plan:
        cmd_genomes_plan(ctx, args)
    else:
        _print_tool_report(ctx, GENOMES_REPORT_TOOLS)
        print("Skipping genomes plan checks by default; running build directly.")

    genomes_cfg, actual_versions, selected_versions, orgs = _prepare_genomes_config(ctx, args)
    print("Resolved tool versions:", json.dumps(actual_versions, indent=2))
    print("Using index version labels:", json.dumps(selected_versions, indent=2))
    tmp_genomes_cfg_path = _write_temp_config_json(genomes_cfg, prefix="bcfngs-genomes-")
    smk = REPO_ROOT / "workflow" / "genomes.smk"

    snakemake_cmd: list[str] = ["snakemake", "--printshellcmds"]
    if args.executor == "slurm":
        _require_snakemake_slurm_executor(ctx)
        print(f"Using SLURM executor (max concurrent jobs: {args.jobs}).")
        snakemake_cmd += ["--executor", "slurm", "--jobs", str(args.jobs)]

        runtime_min = _slurm_time_to_minutes(args.slurm_time)
        slurm_extra_parts = []
        if args.slurm_mail_user:
            slurm_extra_parts.append(f"--mail-user={args.slurm_mail_user}")
        if args.slurm_mail_type:
            slurm_extra_parts.append(f"--mail-type={args.slurm_mail_type}")
        if args.slurm_account:
            slurm_extra_parts.append(f"--account={args.slurm_account}")
        if args.slurm_exclusive:
            slurm_extra_parts.append("--exclusive")

        default_resources = [
            f"slurm_partition={args.slurm_partition!r}",
            f"runtime={runtime_min}",
            "cpus_per_task=1",
            "mem_mb=4096",
        ]
        if args.slurm_qos:
            default_resources.append(f"slurm_qos={args.slurm_qos!r}")
        if slurm_extra_parts:
            default_resources.append(f"slurm_extra={' '.join(slurm_extra_parts)!r}")

        set_resources = [
            f"star_index:cpus_per_task={_as_int(args.slurm_cpus_per_task, field='slurm_cpus_per_task', minimum=1)}",
            f"bowtie2_index:cpus_per_task={_as_int(args.slurm_cpus_per_task, field='slurm_cpus_per_task', minimum=1)}",
            "download_sources:cpus_per_task=1",
            "chrom_size:cpus_per_task=1",
            "bwa_index:cpus_per_task=1",
        ]

        if args.slurm_mem_per_cpu is not None:
            mem_per_cpu = _as_int(args.slurm_mem_per_cpu, field="slurm_mem_per_cpu", minimum=1)
            light_mem = min(mem_per_cpu, 4096)
            set_resources += [
                f"star_index:mem_mb_per_cpu={mem_per_cpu}",
                f"bowtie2_index:mem_mb_per_cpu={mem_per_cpu}",
                f"bwa_index:mem_mb_per_cpu={mem_per_cpu}",
                f"download_sources:mem_mb_per_cpu={light_mem}",
                f"chrom_size:mem_mb_per_cpu={light_mem}",
            ]
        else:
            mem_mb = _as_int(args.slurm_mem, field="slurm_mem", minimum=1)
            light_mem = min(mem_mb, 4096)
            set_resources += [
                f"star_index:mem_mb={mem_mb}",
                f"bowtie2_index:mem_mb={mem_mb}",
                f"bwa_index:mem_mb={mem_mb}",
                f"download_sources:mem_mb={light_mem}",
                f"chrom_size:mem_mb={light_mem}",
            ]

        snakemake_cmd += ["--default-resources", *default_resources, "--set-resources", *set_resources]
    else:
        snakemake_cmd += ["--cores", str(args.cores)]

    snakemake_cmd += ["-s", str(smk), "--configfile", str(tmp_genomes_cfg_path)]
    try:
        _run_tool(ctx, snakemake_cmd)
        _postprocess_genomes_build(
            genomes_cfg,
            orgs,
            runtime=_runtime(ctx),
            build_versions=selected_versions,
        )
    finally:
        tmp_genomes_cfg_path.unlink(missing_ok=True)


def _as_int(value: object, *, field: str, minimum: int | None = None) -> int:
    try:
        out = int(value)
    except (TypeError, ValueError) as e:
        raise SystemExit(f"Invalid integer for {field}: {value!r}") from e
    if minimum is not None and out < minimum:
        raise SystemExit(f"Invalid value for {field}: {out} (must be >= {minimum})")
    return out


def _parse_mappers(raw: str) -> list[str]:
    items = [x.strip().lower() for x in raw.split(",") if x.strip()]
    if not items:
        raise SystemExit("No mapper selected. Use --mapper star,bwa,bowtie2.")
    seen: set[str] = set()
    out: list[str] = []
    for item in items:
        if item not in ALLOWED_MAPPERS:
            raise SystemExit(
                f"Unknown mapper: {item}. Allowed values: {', '.join(sorted(ALLOWED_MAPPERS))}"
            )
        if item not in seen:
            seen.add(item)
            out.append(item)
    return out


def _single_cli_value(raw: object, *, flag: str) -> str | None:
    if raw is None:
        return None
    if isinstance(raw, list):
        values = [str(item).strip() for item in raw if str(item).strip()]
        if not values:
            return None
        if len(values) > 1:
            raise SystemExit(f"{flag} may only be provided once.")
        return values[0]
    value = str(raw).strip()
    return value or None


def _token_matches_flag(token: str, flag: str) -> bool:
    if flag.startswith("--"):
        return token == flag or token.startswith(f"{flag}=")
    if token == flag:
        return True
    return len(flag) == 2 and flag.startswith("-") and token.startswith(flag) and len(token) > len(flag)


def _parse_extra_args_entry(raw: str, *, mapper: str, source: str) -> list[str]:
    try:
        tokens = shlex.split(raw)
    except ValueError as exc:
        raise SystemExit(f"Could not parse extra args for mapper {mapper} from {source}: {exc}") from exc
    if not tokens:
        raise SystemExit(f"Empty extra-args entry for mapper {mapper} in {source}.")
    if tokens[0] == "--":
        raise SystemExit(f"Unsupported '--' token in extra args for mapper {mapper} from {source}.")
    if not tokens[0].startswith("-"):
        raise SystemExit(
            f"Each extra-args entry for mapper {mapper} must start with an option flag; got {tokens[0]!r} in {source}."
        )
    return tokens


def _parse_cli_extra_args(raw: str, *, mapper: str) -> list[list[str]]:
    try:
        tokens = shlex.split(raw)
    except ValueError as exc:
        raise SystemExit(f"Could not parse {MAPPER_EXTRA_ARGS_FLAG[mapper]}: {exc}") from exc
    if not tokens:
        return []

    groups: list[list[str]] = []
    current: list[str] = []
    for token in tokens:
        if token == "--":
            raise SystemExit(f"Unsupported '--' token in {MAPPER_EXTRA_ARGS_FLAG[mapper]}.")
        if token.startswith("-"):
            if current:
                groups.append(current)
            current = [token]
            continue
        if not current:
            raise SystemExit(f"{MAPPER_EXTRA_ARGS_FLAG[mapper]} must start with an option flag; got {token!r}.")
        current.append(token)
    if current:
        groups.append(current)
    return groups


def _validate_extra_arg_groups(mapper: str, groups: Iterable[list[str]]) -> None:
    protected = MAPPER_PROTECTED_FLAGS[mapper]
    for group in groups:
        if not group:
            continue
        token = group[0]
        for flag in protected:
            if _token_matches_flag(token, flag):
                raise SystemExit(
                    f"Protected mapper flag {flag!r} may not be supplied via extra args for {mapper}. "
                    "This workflow manages that setting itself."
                )


def _load_mapper_args_config(ctx: RunContext, path: Path) -> dict[str, list[list[str]]]:
    if not path.exists():
        raise SystemExit(f"Mapper args config file not found: {path}")
    if not path.is_file():
        raise SystemExit(f"Mapper args config path is not a file: {path}")

    raw_cfg = _load_yaml(ctx, path)
    if raw_cfg is None:
        raw_cfg = {}
    if not isinstance(raw_cfg, dict):
        raise SystemExit(f"Mapper args config {path} must contain a top-level mapping.")

    raw_mappers = raw_cfg.get("mappers", {})
    if raw_mappers is None:
        raw_mappers = {}
    if not isinstance(raw_mappers, dict):
        raise SystemExit(f"Mapper args config {path} must define 'mappers' as a mapping.")

    out: dict[str, list[list[str]]] = {mapper: [] for mapper in ALLOWED_MAPPERS}
    for mapper, mapper_cfg in raw_mappers.items():
        mapper_name = str(mapper).strip().lower()
        if mapper_name not in ALLOWED_MAPPERS:
            raise SystemExit(
                f"Unsupported mapper section {mapper!r} in {path}. Allowed values: {', '.join(sorted(ALLOWED_MAPPERS))}"
            )
        if mapper_cfg is None:
            continue
        if not isinstance(mapper_cfg, dict):
            raise SystemExit(f"Mapper section {mapper!r} in {path} must be a mapping.")
        raw_entries = mapper_cfg.get("extra_args", [])
        if raw_entries is None:
            raw_entries = []
        if not isinstance(raw_entries, list):
            raise SystemExit(
                f"Mapper args config {path} requires mappers.{mapper_name}.extra_args to be a list of strings."
            )
        for idx, entry in enumerate(raw_entries, start=1):
            if not isinstance(entry, str):
                raise SystemExit(
                    f"Mapper args config {path} requires mappers.{mapper_name}.extra_args[{idx}] to be a string."
                )
            if not entry.strip():
                continue
            out[mapper_name].append(
                _parse_extra_args_entry(
                    entry,
                    mapper=mapper_name,
                    source=f"{path} (mappers.{mapper_name}.extra_args[{idx}])",
                )
            )
    return out


def _resolve_mapper_extra_args(ctx: RunContext, args: argparse.Namespace, mappers: list[str]) -> dict[str, list[str]]:
    selected_mappers = set(mappers)
    cli_groups: dict[str, list[list[str]]] = {mapper: [] for mapper in ALLOWED_MAPPERS}
    for mapper, attr in MAPPER_EXTRA_ARGS_ATTR.items():
        value = _single_cli_value(getattr(args, attr, None), flag=MAPPER_EXTRA_ARGS_FLAG[mapper])
        if not value:
            continue
        if mapper not in selected_mappers:
            raise SystemExit(f"{MAPPER_EXTRA_ARGS_FLAG[mapper]} may only be used when --mapper includes {mapper}.")
        cli_groups[mapper] = _parse_cli_extra_args(value, mapper=mapper)

    config_path_raw = _single_cli_value(getattr(args, "mapper_args_config", None), flag="--mapper-args-config")
    file_groups: dict[str, list[list[str]]] = {mapper: [] for mapper in ALLOWED_MAPPERS}
    if config_path_raw:
        file_groups = _load_mapper_args_config(ctx, Path(config_path_raw).expanduser())
        for mapper, groups in file_groups.items():
            if groups and mapper not in selected_mappers:
                raise SystemExit(
                    f"Mapper args config {config_path_raw} defines extra args for {mapper}, "
                    f"but --mapper does not include {mapper}."
                )

    merged: dict[str, list[str]] = {}
    for mapper in ALLOWED_MAPPERS:
        groups = cli_groups[mapper] + file_groups[mapper]
        _validate_extra_arg_groups(mapper, groups)
        tokens = [token for group in groups for token in group]
        merged[mapper] = tokens
    return merged


def _slurm_time_to_minutes(s: str) -> int:
    if re.fullmatch(r"\d+", s):
        mins = int(s)
        if mins < 1:
            raise SystemExit(f"Invalid --slurm-time value: {s!r}. Use a positive integer (minutes) or HH:MM:SS.")
        return mins
    m = re.fullmatch(r"(\d+):([0-5]\d):([0-5]\d)", s)
    if not m:
        raise SystemExit(
            f"Invalid --slurm-time value: {s!r}. Use minutes (e.g. 600) or HH:MM:SS (e.g. 04:00:00)."
        )
    h, mins, secs = map(int, m.groups())
    total = (h * 3600) + (mins * 60) + secs
    return max(1, total // 60)


def _mapping_report_tools(mappers: Iterable[str]) -> list[str]:
    tool_keys = list(MAPPING_BASE_REPORT_TOOLS)
    for mapper in mappers:
        if mapper not in tool_keys:
            tool_keys.append(mapper)
    return tool_keys


def _mapping_organism_or_exit(ctx: RunContext, args: argparse.Namespace) -> str:
    organism = str(args.organism).strip()
    if not organism:
        print("Missing required --organism. Showing configured organism keys so you can choose one.")
        cmd_list_org(ctx.env_prefix)
        raise SystemExit("Choose one of the listed organism keys and rerun with --organism.")
    if "," in organism:
        raise SystemExit("Mapping supports exactly one organism per run. Do not pass a comma-separated list.")
    return organism


def _resolve_mapping_index_paths(
    ctx: RunContext,
    genomes_root: Path,
    organism: str,
    assembly: str,
    mappers: list[str],
    args: argparse.Namespace,
) -> tuple[dict[str, str], dict[str, Path]]:
    requested_versions = _requested_index_versions_from_args(args)
    for tool_key, version in requested_versions.items():
        if version and tool_key not in mappers:
            raise SystemExit(f"--{tool_key}-index-version may only be used when --mapper includes {tool_key}.")

    selected_versions: dict[str, str] = {}
    selected_paths: dict[str, Path] = {}
    for tool_key in mappers:
        actual_version = _tool_version_or_fail(ctx, tool_key)
        requested_version = requested_versions[tool_key]
        if requested_version:
            if requested_version != actual_version:
                raise SystemExit(
                    f"--{tool_key}-index-version {requested_version!r} does not match the resolved "
                    f"{TOOL_SPECS[tool_key].display_name} binary version {actual_version!r}."
                )
            selected_versions[tool_key] = requested_version
            selected_paths[tool_key] = (
                _tool_existing_versioned_dir(
                    genomes_root,
                    organism,
                    tool_key,
                    requested_version,
                    assembly=assembly,
                )
                or _tool_versioned_dir(
                    genomes_root,
                    organism,
                    tool_key,
                    requested_version,
                    assembly=assembly,
                )
            )
        else:
            stable_link = _tool_stable_link(genomes_root, organism, tool_key)
            stable_version = _stable_link_version(stable_link, tool_key)
            if stable_version is None:
                raise SystemExit(
                    f"Could not determine the version behind {stable_link}. "
                    f"Use --{tool_key}-index-version to select a matching versioned index explicitly."
                )
            if stable_version != actual_version:
                raise SystemExit(
                    f"Resolved {TOOL_SPECS[tool_key].display_name} binary version {actual_version!r} does not match "
                    f"the stable {_tool_index_dirname(tool_key)} target version {stable_version!r}. "
                    f"Use --{tool_key}-index-version {actual_version}."
                )
            selected_versions[tool_key] = stable_version
            selected_paths[tool_key] = stable_link

        expected_candidates = _tool_expected_index_paths(
            genomes_root,
            organism,
            tool_key,
            selected_versions[tool_key] if requested_version else None,
            assembly=assembly if requested_version else None,
        )
        expected = next((path for path in expected_candidates if path.exists()), None)
        if expected is None:
            raise SystemExit(
                f"Missing required {TOOL_SPECS[tool_key].display_name} index resource: {expected_candidates[0]}"
            )
    return selected_versions, selected_paths


def _resolve_mapping_settings(ctx: RunContext, args: argparse.Namespace) -> MappingSettings:
    genomes_cfg_path = REPO_ROOT / "configs" / "genomes.yaml"
    workflow_path = REPO_ROOT / "workflow" / "mapping.smk"

    genomes_cfg = _load_yaml(ctx, genomes_cfg_path)

    project = str(args.project).strip() or DEFAULT_MAPPING_PROJECT

    organism = _mapping_organism_or_exit(ctx, args)
    fastq_dir_raw = str(args.fastq_dir).strip() or str(Path.cwd())
    fastq_dir = Path(fastq_dir_raw).expanduser()
    if not fastq_dir.exists() or not fastq_dir.is_dir():
        raise SystemExit(f"FASTQ directory not found or not a directory: {fastq_dir}")

    outdir_raw = str(args.outdir).strip() or str(Path.cwd())
    outdir = Path(outdir_raw).expanduser()
    _check_write_permission(outdir)

    mappers = _parse_mappers(args.mapper)
    read_mode = "paired" if args.paired_end else "single"
    mapper_extra_args = _resolve_mapper_extra_args(ctx, args, mappers)

    threads = _as_int(args.threads, field="threads", minimum=1)
    ram_bytes = _as_int(args.ram_bytes, field="ram_bytes", minimum=1)
    bw_bin_size = _as_int(args.bw_bin_size, field="bw_bin_size", minimum=1)
    bw_normalization = str(args.bw_normalization).strip()
    if not bw_normalization:
        raise SystemExit("Empty --bw-normalization value is not allowed.")

    genomes_root = Path(genomes_cfg.get("genomes_root", "/fs/pool/pool-bcfngs/genomes")).expanduser()
    if not genomes_root.exists():
        raise SystemExit(f"Configured genomes_root does not exist: {genomes_root}")

    configured_assembly = _assembly_for_org(genomes_cfg, organism)
    manifest_assembly = _manifest_assembly(genomes_root, organism)
    if manifest_assembly and manifest_assembly != configured_assembly:
        raise SystemExit(
            f"Configured assembly {configured_assembly!r} for {organism} does not match the last built "
            f"assembly {manifest_assembly!r} recorded in {genomes_root / organism / MANIFEST_FILE_NAME}. "
            "Rebuild the genome indices before mapping."
        )
    for tool_key in mappers:
        stable_assembly = _stable_link_assembly(_tool_stable_link(genomes_root, organism, tool_key), tool_key)
        if stable_assembly and stable_assembly != configured_assembly:
            raise SystemExit(
                f"Stable {_tool_index_dirname(tool_key)} target for {organism} points to assembly "
                f"{stable_assembly!r}, but configs/genomes.yaml now requests {configured_assembly!r}. "
                "Rebuild the genome indices before mapping."
            )

    index_versions, index_paths = _resolve_mapping_index_paths(
        ctx,
        genomes_root,
        organism,
        configured_assembly,
        mappers,
        args,
    )

    missing_indices: list[str] = []
    if "star" in mappers and not (index_paths["star"] / "SA").exists():
        missing_indices.append(str(index_paths["star"] / "SA"))
    if "bwa" in mappers and not (index_paths["bwa"] / f"{organism}.bwt").exists():
        missing_indices.append(str(index_paths["bwa"] / f"{organism}.bwt"))
    if "bowtie2" in mappers and not (index_paths["bowtie2"] / f"{organism}.1.bt2").exists():
        missing_indices.append(str(index_paths["bowtie2"] / f"{organism}.1.bt2"))
    if not (genomes_root / f"{organism}.chromSize").exists():
        missing_indices.append(str(genomes_root / f"{organism}.chromSize"))
    if missing_indices:
        pretty = "\n  - ".join([""] + missing_indices)
        raise SystemExit(f"Missing required genome resource(s):{pretty}")

    return MappingSettings(
        workflow_path=workflow_path,
        project=project,
        organism=organism,
        fastq_dir=fastq_dir,
        outdir=outdir,
        genomes_root=genomes_root,
        mappers=mappers,
        read_mode=read_mode,
        threads=threads,
        ram_bytes=ram_bytes,
        bw_bin_size=bw_bin_size,
        bw_normalization=bw_normalization,
        index_versions=index_versions,
        index_paths=index_paths,
        mapper_extra_args=mapper_extra_args,
    )


def _mapping_config(settings: MappingSettings) -> dict:
    config_data = {
        "project": settings.project,
        "organism": settings.organism,
        "fastq_dir": str(settings.fastq_dir),
        "outdir": str(settings.outdir),
        "genomes_root": str(settings.genomes_root),
        "mappers": ",".join(settings.mappers),
        "read_mode": settings.read_mode,
        "threads": settings.threads,
        "ram_bytes": settings.ram_bytes,
        "bw_bin_size": settings.bw_bin_size,
        "bw_normalization": settings.bw_normalization,
        "mapper_extra_args": settings.mapper_extra_args,
    }
    if "star" in settings.index_paths:
        config_data["star_index_dir"] = str(settings.index_paths["star"])
    if "bwa" in settings.index_paths:
        config_data["bwa_index_prefix"] = str(settings.index_paths["bwa"] / settings.organism)
    if "bowtie2" in settings.index_paths:
        config_data["bowtie2_index_prefix"] = str(settings.index_paths["bowtie2"] / settings.organism)
    return config_data


def _mapping_snakemake_cmd(
    settings: MappingSettings,
    args: argparse.Namespace,
    *,
    dry_run: bool,
    config_path: Path,
) -> list[str]:
    cmd = [
        "snakemake",
        "--printshellcmds",
        "-s",
        str(settings.workflow_path),
        "--configfile",
        str(config_path),
        "--latency-wait",
        str(args.latency_wait),
    ]
    if dry_run:
        cmd.append("--dry-run")

    if args.executor == "local":
        cmd += ["--jobs", str(args.jobs)]
        return cmd

    runtime_min = _slurm_time_to_minutes(args.slurm_time)
    slurm_extra_parts: list[str] = []
    if args.slurm_mail_user:
        slurm_extra_parts.append(f"--mail-user={args.slurm_mail_user}")
    if args.slurm_mail_type:
        slurm_extra_parts.append(f"--mail-type={args.slurm_mail_type}")
    if args.slurm_account:
        slurm_extra_parts.append(f"--account={args.slurm_account}")

    default_resources = [
        f"slurm_partition={args.slurm_partition!r}",
        f"runtime={runtime_min}",
        "cpus_per_task=1",
        "mem_mb=4096",
    ]
    if slurm_extra_parts:
        default_resources.append(f"slurm_extra={' '.join(slurm_extra_parts)!r}")

    mapper_cpus = _as_int(args.slurm_cpus_per_task, field="slurm_cpus_per_task", minimum=1)
    star_mem_mb = _as_int(args.slurm_star_mem_mb, field="slurm_star_mem_mb", minimum=1)
    aligner_mem_mb = _as_int(args.slurm_aligner_mem_mb, field="slurm_aligner_mem_mb", minimum=1)
    bigwig_cpus = _as_int(args.slurm_bigwig_cpus, field="slurm_bigwig_cpus", minimum=1)
    bigwig_mem_mb = _as_int(args.slurm_bigwig_mem_mb, field="slurm_bigwig_mem_mb", minimum=1)
    index_mem_mb = _as_int(args.slurm_index_mem_mb, field="slurm_index_mem_mb", minimum=1)

    set_resources = [
        f"map_star:cpus_per_task={mapper_cpus}",
        f"map_star:mem_mb={star_mem_mb}",
        f"map_bwa:cpus_per_task={mapper_cpus}",
        f"map_bwa:mem_mb={aligner_mem_mb}",
        f"map_bowtie2:cpus_per_task={mapper_cpus}",
        f"map_bowtie2:mem_mb={aligner_mem_mb}",
        "index_bam:cpus_per_task=1",
        f"index_bam:mem_mb={index_mem_mb}",
        f"create_bigwig:cpus_per_task={bigwig_cpus}",
        f"create_bigwig:mem_mb={bigwig_mem_mb}",
    ]

    cmd += [
        "--executor",
        "slurm",
        "--jobs",
        str(args.jobs),
        "--default-resources",
        *default_resources,
        "--set-resources",
        *set_resources,
    ]
    return cmd


def _run_mapping_lint(ctx: RunContext, settings: MappingSettings, config_path: Path) -> None:
    cmd = [
        "snakemake",
        "--lint",
        "-s",
        str(settings.workflow_path),
        "--configfile",
        str(config_path),
    ]
    lint_cp = _run_tool(ctx, cmd, check=False, capture=True)
    if lint_cp.returncode != 0:
        print(f"Warning: snakemake --lint returned exit code {lint_cp.returncode}; continuing with dry-run.")
        lint_out = (lint_cp.stdout or "").strip()
        lint_err = (lint_cp.stderr or "").strip()
        if lint_out:
            print(lint_out)
        if lint_err:
            print(lint_err)


def _print_mapping_summary(settings: MappingSettings, args: argparse.Namespace) -> None:
    print(
        "Mapping settings:",
        json.dumps(
            {
                "project": settings.project,
                "organism": settings.organism,
                "fastq_dir": str(settings.fastq_dir),
                "outdir": str(settings.outdir),
                "mappers": settings.mappers,
                "read_mode": settings.read_mode,
                "threads": settings.threads,
                "ram_bytes": settings.ram_bytes,
                "executor": args.executor,
                "bw_bin_size": settings.bw_bin_size,
                "bw_normalization": settings.bw_normalization,
                "index_versions": settings.index_versions,
                "index_paths": {tool: str(path) for tool, path in settings.index_paths.items()},
                "mapper_extra_args": {tool: shlex.join(tokens) for tool, tokens in settings.mapper_extra_args.items()},
            },
            indent=2,
        ),
    )


def cmd_mapping_plan(ctx: RunContext, args: argparse.Namespace) -> None:
    _mapping_organism_or_exit(ctx, args)
    mappers = _parse_mappers(args.mapper)
    _print_tool_report(ctx, _mapping_report_tools(mappers))
    settings = _resolve_mapping_settings(ctx, args)
    _print_mapping_summary(settings, args)
    tmp_mapping_cfg_path = _write_temp_config_json(_mapping_config(settings), prefix="bcfngs-mapping-")
    try:
        _run_mapping_lint(ctx, settings, tmp_mapping_cfg_path)
        _run_tool(ctx, _mapping_snakemake_cmd(settings, args, dry_run=True, config_path=tmp_mapping_cfg_path))
    finally:
        tmp_mapping_cfg_path.unlink(missing_ok=True)


def cmd_mapping_run(ctx: RunContext, args: argparse.Namespace) -> None:
    _mapping_organism_or_exit(ctx, args)
    mappers = _parse_mappers(args.mapper)
    _print_tool_report(ctx, _mapping_report_tools(mappers))
    settings = _resolve_mapping_settings(ctx, args)
    _print_mapping_summary(settings, args)
    tmp_mapping_cfg_path = _write_temp_config_json(_mapping_config(settings), prefix="bcfngs-mapping-")
    try:
        _run_tool(ctx, _mapping_snakemake_cmd(settings, args, dry_run=False, config_path=tmp_mapping_cfg_path))
    finally:
        tmp_mapping_cfg_path.unlink(missing_ok=True)


def _add_index_version_args(parser: argparse.ArgumentParser) -> None:
    parser.add_argument("--star-index-version", help="Require/use this STAR index version label.")
    parser.add_argument("--bwa-index-version", help="Require/use this bwa index version label.")
    parser.add_argument("--bowtie2-index-version", help="Require/use this bowtie2 index version label.")


def _add_mapping_args(parser: argparse.ArgumentParser) -> None:
    parser.add_argument(
        "--mapper",
        default="star",
        help="Comma-separated mapper list: star,bwa,bowtie2 (default: star)",
    )
    mode = parser.add_mutually_exclusive_group()
    mode.add_argument("--paired-end", dest="paired_end", action="store_true", help="Use paired-end FASTQ input (default).")
    mode.add_argument("--single-end", dest="paired_end", action="store_false", help="Use single-end FASTQ input.")
    parser.set_defaults(paired_end=True)

    parser.add_argument(
        "--project",
        default=DEFAULT_MAPPING_PROJECT,
        help=f"Project identifier used in the output layout (default: {DEFAULT_MAPPING_PROJECT}).",
    )
    parser.add_argument(
        "--input",
        "--fastq-dir",
        dest="fastq_dir",
        default=str(Path.cwd()),
        help="FASTQ input directory (default: current working directory).",
    )
    parser.add_argument(
        "--output",
        "--outdir",
        dest="outdir",
        default=str(Path.cwd()),
        help="Output root directory (default: current working directory).",
    )
    parser.add_argument(
        "--organism",
        default="",
        help="Organism key from configs/genomes.yaml. Required for mapping; use --list-org to see choices.",
    )
    parser.add_argument(
        "--threads",
        type=int,
        default=DEFAULT_MAPPING_THREADS,
        help=f"Mapping threads per job (default: {DEFAULT_MAPPING_THREADS}).",
    )
    parser.add_argument(
        "--ram-bytes",
        "--ram_bytes",
        dest="ram_bytes",
        type=int,
        default=DEFAULT_MAPPING_RAM_BYTES,
        help=f"STAR --limitBAMsortRAM value in bytes (default: {DEFAULT_MAPPING_RAM_BYTES}).",
    )
    _add_index_version_args(parser)
    parser.add_argument(
        "--mapper-args-config",
        action="append",
        default=None,
        help="Optional YAML file with mapper-specific extra args, e.g. mappers.star.extra_args.",
    )
    parser.add_argument(
        "--extra-star-align-args",
        action="append",
        default=None,
        help='Single shell-quoted STAR extra-args string, e.g. "--alignIntronMax 1 --alignEndsType EndToEnd".',
    )
    parser.add_argument(
        "--extra-bwa-args",
        action="append",
        default=None,
        help='Single shell-quoted bwa extra-args string, e.g. "-k 1".',
    )
    parser.add_argument(
        "--extra-bowtie2-args",
        action="append",
        default=None,
        help='Single shell-quoted bowtie2 extra-args string, e.g. "--very-sensitive".',
    )
    parser.add_argument(
        "--keep-intermediary-files",
        action="store_true",
        help="Deprecated. STAR outputs and STAR log files are kept by default.",
    )
    parser.add_argument("--bw-bin-size", type=int, default=10, help="bamCoverage --binSize (default: 10).")
    parser.add_argument(
        "--bw-normalization",
        default="CPM",
        help="bamCoverage --normalizeUsing value (default: CPM).",
    )

    parser.add_argument("--executor", choices=["local", "slurm"], default="local", help="Execution backend (default: local).")
    parser.add_argument("--jobs", type=int, default=20, help="Max concurrent jobs (default: 20).")
    parser.add_argument("--latency-wait", type=int, default=10, help="Snakemake latency wait in seconds (default: 10).")

    parser.add_argument("--slurm-partition", default=DEFAULT_SLURM_PARTITION, help=f"SLURM partition (default: {DEFAULT_SLURM_PARTITION}).")
    parser.add_argument("--slurm-time", default=DEFAULT_SLURM_TIME, help=f"SLURM walltime HH:MM:SS (default: {DEFAULT_SLURM_TIME}).")
    parser.add_argument("--slurm-mail-user", default=DEFAULT_SLURM_MAIL_USER, help=f"SLURM mail user (default: {DEFAULT_SLURM_MAIL_USER}).")
    parser.add_argument("--slurm-mail-type", default=DEFAULT_SLURM_MAIL_TYPE, help=f"SLURM mail type (default: {DEFAULT_SLURM_MAIL_TYPE}).")
    parser.add_argument("--slurm-account", default="", help="Optional SLURM account.")
    parser.add_argument("--slurm-cpus-per-task", type=int, default=20, help="Mapper rule cpus-per-task on SLURM (default: 20).")
    parser.add_argument("--slurm-star-mem-mb", type=int, default=64000, help="SLURM mem_mb for STAR mapping rule (default: 64000).")
    parser.add_argument("--slurm-aligner-mem-mb", type=int, default=32000, help="SLURM mem_mb for BWA/Bowtie2 mapping rules (default: 32000).")
    parser.add_argument("--slurm-index-mem-mb", type=int, default=4096, help="SLURM mem_mb for BAM indexing rule (default: 4096).")
    parser.add_argument("--slurm-bigwig-cpus", type=int, default=4, help="SLURM cpus-per-task for bamCoverage rule (default: 4).")
    parser.add_argument("--slurm-bigwig-mem-mb", type=int, default=8192, help="SLURM mem_mb for bamCoverage rule (default: 8192).")


def main() -> None:
    pre_parser = argparse.ArgumentParser(add_help=False)
    pre_parser.add_argument("--profile", choices=["micromamba", "modules"], default="micromamba")
    pre_parser.add_argument(
        "--env-prefix",
        default=str(DEFAULT_ENV_PREFIX),
        help="Micromamba environment prefix (default: cluster env if present, else .mamba/env).",
    )
    pre_parser.add_argument(
        "--list-org",
        action="store_true",
        help="List configured organism keys with assembly build and pinned source release, then exit.",
    )

    pre_args, _ = pre_parser.parse_known_args()
    if pre_args.list_org:
        cmd_list_org(Path(pre_args.env_prefix))
        return

    parser = argparse.ArgumentParser(prog="bcfngs", parents=[pre_parser])

    sub = parser.add_subparsers(dest="cmd", required=True)

    env_p = sub.add_parser("env")
    env_sub = env_p.add_subparsers(dest="env_cmd", required=True)
    env_sub.add_parser("create")
    env_sub.add_parser("update")
    env_sub.add_parser("check")

    genomes_p = sub.add_parser("genomes")
    genomes_sub = genomes_p.add_subparsers(dest="genomes_cmd", required=True)
    genomes_sub.add_parser("check-updates")
    plan_p = genomes_sub.add_parser("plan")
    plan_p.add_argument("--organism", help="Comma-separated subset of organism keys (e.g. Homo_sapiens,Mus_musculus)")
    _add_index_version_args(plan_p)
    build_p = genomes_sub.add_parser("build")
    build_p.add_argument(
        "--executor",
        choices=["local", "slurm"],
        default="local",
        help="Execution backend: local (default) or slurm.",
    )
    build_p.add_argument("--cores", type=int, default=16)
    build_p.add_argument("--jobs", type=int, default=20, help="Max concurrent jobs for --executor slurm.")
    build_p.add_argument(
        "--slurm-partition",
        default=DEFAULT_SLURM_PARTITION,
        help="SLURM partition name (for --executor slurm).",
    )
    build_p.add_argument("--slurm-account", help="SLURM account name (for --executor slurm).")
    build_p.add_argument("--slurm-qos", help="SLURM QoS name (for --executor slurm).")
    build_p.add_argument(
        "--slurm-mail-user",
        default=DEFAULT_SLURM_MAIL_USER,
        help="SLURM mail user for --executor slurm.",
    )
    build_p.add_argument(
        "--slurm-mail-type",
        default=DEFAULT_SLURM_MAIL_TYPE,
        help="SLURM mail type for --executor slurm (e.g. ALL or END,FAIL).",
    )
    build_p.add_argument(
        "--slurm-time",
        default=DEFAULT_SLURM_TIME,
        help=f"SLURM walltime HH:MM:SS (default: {DEFAULT_SLURM_TIME}).",
    )
    build_p.add_argument(
        "--slurm-cpus-per-task",
        type=int,
        default=20,
        help="SLURM cpus-per-task for heavy index rules (default: 20).",
    )
    build_p.add_argument(
        "--slurm-mem-per-cpu",
        type=int,
        default=None,
        help="SLURM mem-per-cpu in MB for --executor slurm (optional). If set, this overrides --slurm-mem.",
    )
    build_p.add_argument(
        "--slurm-mem",
        type=int,
        default=DEFAULT_SLURM_MEM_MB,
        help=f"SLURM total memory (--mem) in MB for heavy index rules (default: {DEFAULT_SLURM_MEM_MB} ~= 400G). Ignored when --slurm-mem-per-cpu is set.",
    )
    build_p.add_argument(
        "--slurm-exclusive",
        action="store_true",
        help="Request exclusive node allocation per submitted SLURM job.",
    )
    build_p.add_argument("--organism", help="Comma-separated subset of organism keys (e.g. Homo_sapiens,Mus_musculus)")
    _add_index_version_args(build_p)
    build_p.add_argument(
        "-no-skip-plan",
        "--no-skip-plan",
        action="store_true",
        help="Run plan preflight checks before build (config validation, URL checks, lint, dry-run).",
    )

    mapping_p = sub.add_parser("mapping")
    mapping_sub = mapping_p.add_subparsers(dest="mapping_cmd", required=True)
    mapping_plan_p = mapping_sub.add_parser("plan")
    _add_mapping_args(mapping_plan_p)
    mapping_run_p = mapping_sub.add_parser("run")
    _add_mapping_args(mapping_run_p)

    args = parser.parse_args()
    ctx = RunContext(profile=args.profile, env_prefix=Path(args.env_prefix))

    if args.cmd == "env":
        if ctx.profile == "modules" and args.env_cmd in ("create", "update"):
            raise SystemExit("env create/update require --profile micromamba (they manage the micromamba environment).")
        if args.env_cmd == "create":
            cmd_env_create(ctx, args)
        elif args.env_cmd == "update":
            cmd_env_update(ctx, args)
        elif args.env_cmd == "check":
            cmd_env_check(ctx, args)
        else:
            raise SystemExit("Unknown env command")
        return

    if args.cmd == "genomes":
        if args.genomes_cmd == "check-updates":
            cmd_genomes_check_updates(ctx, args)
        elif args.genomes_cmd == "plan":
            cmd_genomes_plan(ctx, args)
        elif args.genomes_cmd == "build":
            cmd_genomes_build(ctx, args)
        else:
            raise SystemExit("Unknown genomes command")
        return

    if args.cmd == "mapping":
        if args.mapping_cmd == "plan":
            cmd_mapping_plan(ctx, args)
        elif args.mapping_cmd == "run":
            cmd_mapping_run(ctx, args)
        else:
            raise SystemExit("Unknown mapping command")
        return

    raise SystemExit("Unknown command")


if __name__ == "__main__":
    main()
