@dataclass(frozen=True)
class RunContext:
    profile: str
    env_prefix: Path


@dataclass(frozen=True)
class ToolSpec:
    key: str
    display_name: str
    executables: tuple[str, ...]
    version_cmd: tuple[str, ...]
    module_aliases: tuple[str, ...] = ()
    module_default: str | None = None


@dataclass(frozen=True)
class ResolvedTool:
    key: str
    display_name: str
    source: str
    version: str
    module_name: str | None
    executables: dict[str, str]

    def executable(self, name: str | None = None) -> str | None:
        if not self.executables:
            return None
        if name and name in self.executables:
            return self.executables[name]
        return next(iter(self.executables.values()))


@dataclass(frozen=True)
class RuntimeEnvironment:
    env: dict[str, str]
    tools: dict[str, ResolvedTool]
    preloaded_modules: tuple[str, ...]
    auto_loaded_modules: tuple[str, ...]


@dataclass(frozen=True)
class MappingSettings:
    run_cfg_path: Path
    genomes_cfg_path: Path
    workflow_path: Path
    project: str
    organism: str
    fastq_dir: Path
    outdir: Path
    genomes_root: Path
    mappers: list[str]
    read_mode: str
    threads: int
    ram_bytes: int
    keep_intermediary_files: bool
    bw_bin_size: int
    bw_normalization: str
    index_versions: dict[str, str]
    index_paths: dict[str, Path]


